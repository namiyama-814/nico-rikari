doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      integrity="sha256-fx038NkLY4U1TCrBDiu5FWPEa9eiZu01EiLryshJbCo="
      crossorigin="anonymous")
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet")

    link(rel="stylesheet", href="style.css")
    title ニコニコ動画(Re:仮) - 復元
  body 
    .page-wrapper
      .container.text-center.my-2
        h3 ニコニコ動画(Re:仮) - 復元
        p ニコニコ動画(Re:仮)の復元サービスです。
          br
          | 本家様とは仕組みが異なるのでニコニコのサーバーが落ちるとこちらも落ちます。
  
      #videoArea.container
        .row.row-cols-2.row-cols-md-3.row-cols-lg-5.g-3
          each video in videos
            .col
              .card.shadow-sm.h-100.video-card(data-id=video.id)
                .card.shadow-sm.h-100
        
                  .thumbnail-wrapper
                    .ratio.ratio-16x9
                      img.thumbnail(src=video.thumbnail)
        
                    span.video-time #{video.videoTime}
        
                  .card-body.d-flex.flex-column
                    h6.card-title.mb-1= video.title
                    p.card-text= video.description
        
                    .mt-auto.text-end.small.text-muted
                      | #{video.time}
      .text-center.my-2
        a(href="/")
          | 動画一覧を再読み込み
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    #videoModal.modal.fade(tabindex="-1")
      .modal-dialog.modal-lg.modal-dialog-centered
        .modal-content
          .modal-body.p-0
            iframe#videoFrame(
              width="100%"
              height="400"
              frameborder="0"
              allowfullscreen
            )
    script.
      const modal = new bootstrap.Modal(document.getElementById('videoModal'));
      const frame = document.getElementById('videoFrame');
    
      document.querySelectorAll('.video-card').forEach(card=>{
        card.addEventListener('click', ()=>{
          const id = card.dataset.id;
    
          frame.src = `https://embed.nicovideo.jp/watch/${id}`;
          modal.show();
        });
      });
    
      document.getElementById('videoModal')
        .addEventListener('hidden.bs.modal', ()=>{
          frame.src = "";
        });
